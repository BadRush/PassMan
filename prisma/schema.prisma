generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String       @id @default(uuid()) @db.Uuid
  email                 String       @unique
  authKeyHash           String       @map("auth_key_hash")
  saltAuth              String       @map("salt_auth")
  saltEnc               String       @map("salt_enc")
  encryptedPrivateKey   String       @map("encrypted_private_key") @db.Text
  publicKey             String       @map("public_key") @db.Text
  totpEnabled           Boolean      @default(false) @map("totp_enabled")
  totpSecretEncrypted   String?      @map("totp_secret_encrypted")
  recoveryCodesHash     String[]     @map("recovery_codes_hash")
  
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  vaultItems            VaultItem[]
  folders               Folder[]
  tags                  Tag[]
  sessions              Session[]
  auditLogs             AuditLog[]
  sharedItemsOwned      SharedItem[] @relation("OwnedShares")
  sharedItemsReceived   SharedItem[] @relation("ReceivedShares")

  @@map("users")
}

model VaultItem {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid @map("user_id")
  folderId        String?          @db.Uuid @map("folder_id")
  encryptedData   String           @map("encrypted_data") @db.Text
  iv              String
  authTag         String           @map("auth_tag")
  type            String           // "login|note|card|identity"
  isFavorite      Boolean          @default(false) @map("is_favorite")
  sortOrder       Int              @default(0) @map("sort_order")
  
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  lastAccessedAt  DateTime?        @map("last_accessed_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder          Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags            VaultItemTag[]
  sharedVia       SharedItem[]

  @@map("vault_items")
}

model Folder {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @db.Uuid @map("user_id")
  parentId        String?     @db.Uuid @map("parent_id")
  name            String
  icon            String?
  sortOrder       Int         @default(0) @map("sort_order")
  
  createdAt       DateTime    @default(now()) @map("created_at")

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          Folder?     @relation("FolderToFolder", fields: [parentId], references: [id])
  children        Folder[]    @relation("FolderToFolder")
  vaultItems      VaultItem[]

  @@map("folders")
}

model Tag {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @db.Uuid @map("user_id")
  name            String
  color           String?
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaultItems      VaultItemTag[]

  @@unique([userId, name])
  @@map("tags")
}

model VaultItemTag {
  vaultItemId     String     @db.Uuid @map("vault_item_id")
  tagId           String     @db.Uuid @map("tag_id")

  vaultItem       VaultItem  @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  tag             Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([vaultItemId, tagId])
  @@map("vault_item_tags")
}

model SharedItem {
  id              String     @id @default(uuid()) @db.Uuid
  vaultItemId     String     @db.Uuid @map("vault_item_id")
  ownerId         String     @db.Uuid @map("owner_id")
  recipientId     String     @db.Uuid @map("recipient_id")
  encryptedKey    String     @map("encrypted_key") @db.Text // AES key encrypted with recipient public key
  permission      String     // "view|edit"
  
  sharedAt        DateTime   @default(now()) @map("shared_at")
  expiresAt       DateTime?  @map("expires_at")

  vaultItem       VaultItem  @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  owner           User       @relation("OwnedShares", fields: [ownerId], references: [id], onDelete: Cascade)
  recipient       User       @relation("ReceivedShares", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("shared_items")
}

model AuditLog {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @db.Uuid @map("user_id")
  vaultItemId     String?    @db.Uuid @map("vault_item_id")
  action          String     // "view|create|update|delete|share|export"
  ipAddress       String?    @map("ip_address")
  userAgent       String?    @map("user_agent")
  metadata        Json?
  
  createdAt       DateTime   @default(now()) @map("created_at")

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Session {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @db.Uuid @map("user_id")
  tokenHash       String     @unique @map("token_hash")
  ipAddress       String?    @map("ip_address")
  userAgent       String?    @map("user_agent")
  
  createdAt       DateTime   @default(now()) @map("created_at")
  expiresAt       DateTime   @map("expires_at")
  lastActiveAt    DateTime   @default(now()) @map("last_active_at")

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
